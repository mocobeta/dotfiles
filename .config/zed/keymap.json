    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-d": "editor::GoToDefinition",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "f12": "editor::GoToDefinition",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-t": "editor::GoToTypeDefinition",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-f12": "editor::GoToTypeDefinition",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-r": "editor::FindAllReferences",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "alt-shift-f12": "editor::FindAllReferences",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-p": "editor::MoveUp",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "up": "editor::MoveUp",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-b": "editor::MoveLeft",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "left": "editor::MoveLeft",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-f": "editor::MoveRight",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "right": "editor::MoveRight",
    },
  },
  {
    "context": "Editor",
    "bindings": {
