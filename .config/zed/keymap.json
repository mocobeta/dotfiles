  {
    "context": "Editor",
    "bindings": {
      "down": "editor::MoveDown",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "pagedown": "editor::MovePageDown",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-a": [
        "editor::MoveToBeginningOfLine",
        {
          "stop_at_soft_wraps": true,
          "stop_at_indent": true,
        },
      ],
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "home": [
        "editor::MoveToBeginningOfLine",
        {
          "stop_at_soft_wraps": true,
          "stop_at_indent": true,
        },
      ],
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-e": [
        "editor::MoveToEndOfLine",
        {
          "stop_at_soft_wraps": true,
        },
      ],
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "end": [
        "editor::MoveToEndOfLine",
        {
          "stop_at_soft_wraps": true,
        },
      ],
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-d": "editor::Delete",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "delete": "editor::Delete",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-h": "editor::Backspace",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "shift-backspace": "editor::Backspace",
    },
  },
  {
    "bindings": {
      "ctrl-k": "editor::CutToEndOfLine",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "pageup": "editor::MovePageUp",
    },
  },
